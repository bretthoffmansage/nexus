# Nexus environment (copy to `.env.local` — never commit secrets)

# --- Browser-visible (safe for client bundles) ---
# Clerk publishable key from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key

# Clerk hosted auth routes (set by `clerk init` or manually)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Convex deployment URL from `npx convex dev` or the Convex dashboard
NEXT_PUBLIC_CONVEX_URL=your_convex_deployment_url

# --- Server-only (never prefix with NEXT_PUBLIC_) ---
# Clerk secret key — used by proxy and server components
CLERK_SECRET_KEY=your_clerk_secret_key

# Clerk webhook signing secret from Clerk Dashboard → Webhooks
CLERK_WEBHOOK_SECRET=your_clerk_webhook_signing_secret

# Clerk JWT issuer domain for Convex auth (compatibility alias; prefer CLERK_FRONTEND_API_URL)
# Example: https://your-instance.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=your_clerk_jwt_issuer_domain

# Canonical Clerk Frontend API URL from native Convex integration
# Example: https://your-instance.clerk.accounts.dev
CLERK_FRONTEND_API_URL=your_clerk_frontend_api_url

# Shared secret for Next.js webhook route → Convex identity mutations
NEXUS_INTERNAL_API_SECRET=your_internal_api_secret

# Comma-separated bootstrap admin emails (set in Convex dashboard too)
# Used only while no active nexus_admin exists
NEXUS_BOOTSTRAP_ADMIN_EMAILS=

# --- Convex CLI (local development / deploy) ---
# Set automatically when you run `npx convex dev`
# CONVEX_DEPLOYMENT=dev:your-deployment-name
